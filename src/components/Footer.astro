---
import { Icon } from 'astro-icon/components';
---

<footer class="page-footer font-small mdb-color pt-4 bg-dark text-white position-main">
  <div class="container text-center text-md-left">
    <div class="row text-center text-md-left mt-3 pb-3">
      <div class="col-md-6 col-lg-3 col-xl-5 mx-auto mt-3">
        <h6 class="text-uppercase mb-4 font-weight-bold">
          Jesus Alone is God Church of Europe
        </h6>
        <p>
          In case of any question, get in touch with us using the contact
          information under the contact section.
        </p>
      </div>

      <hr class="w-100 clearfix d-md-none" />

      <div class="col-md-4 col-lg-3 col-xl-4 mx-auto mt-3">
        <h6 class="text-uppercase mb-4 font-weight-bold">Contact</h6>
        <p>
          <Icon name="fa-solid:envelope" style="display: inline-block; width: 1em; height: 1em; margin-right: 0.5em;" /> hpaulsilas@hotmail.com
        </p>
      </div>
    </div>
  </div>
</footer>
