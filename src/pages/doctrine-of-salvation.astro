---
import BaseLayout from '../layouts/BaseLayout.astro';
import DoctrineOfSalvationCard from '../components/DoctrineOfSalvationCard.astro';

const podcastModules = import.meta.glob('../content/podcasts/*.json', { eager: true });
const episodes = Object.values(podcastModules)
  .map((mod: any) => mod.default)
  .sort((a, b) => b.order - a.order);
---

<BaseLayout title="Doctrine of Salvation - JESUS ALONE IS GOD CHURCH OF EUROPE">
  <main role="main" class="container mb-2 position-main">
    <DoctrineOfSalvationCard episodes={episodes} />
  </main>
</BaseLayout>
