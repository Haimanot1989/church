---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageDescriber from '../components/PageDescriber.astro';
---

<BaseLayout title="Place of Worship - JESUS ALONE IS GOD CHURCH OF EUROPE">
  <main role="main" class="container position-main">
    <PageDescriber title="Place of Worship" bodyTexts={['Find our meeting locations across Europe']} />
    <div class="card">
      <div class="card-body">
        <h5 class="card-title">Meeting Locations</h5>
        <p class="card-text">
          We gather for worship in various locations across Europe. Please contact us for specific
          meeting times and locations in your area.
        </p>
        <h6>Contact Information</h6>
        <p>Email: hpaulsilas@hotmail.com</p>
      </div>
    </div>
  </main>
</BaseLayout>
