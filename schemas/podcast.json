{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["order", "slug", "title", "episodeUrl"],
  "properties": {
    "order": {
      "type": "number",
      "description": "Sort order (higher numbers appear first)"
    },
    "slug": {
      "type": "string",
      "description": "URL-friendly identifier"
    },
    "title": {
      "type": "string",
      "description": "Podcast episode title"
    },
    "episodeUrl": {
      "type": "string",
      "description": "URL to podcast episode player embed"
    },
    "sermonUrl": {
      "type": "string",
      "description": "Path to associated sermon PDF"
    },
    "date": {
      "type": ["string", "null"],
      "description": "Episode date (YYYY-MM-DD format)"
    }
  }
}
