{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["order", "slug", "title", "summary", "pdfLink", "image"],
  "properties": {
    "order": {
      "type": "number",
      "description": "Sort order (higher numbers appear first)"
    },
    "slug": {
      "type": "string",
      "description": "URL-friendly identifier"
    },
    "title": {
      "type": "string",
      "description": "Book title"
    },
    "subTitle": {
      "type": "string",
      "description": "Book subtitle"
    },
    "summary": {
      "type": "string",
      "description": "Book description"
    },
    "pdfLink": {
      "type": "string",
      "description": "Path to book PDF"
    },
    "image": {
      "type": "string",
      "description": "Path to book cover image"
    },
    "pages": {
      "type": ["number", "string"],
      "description": "Number of pages"
    },
    "date": {
      "type": ["string", "null"],
      "description": "Publication date (YYYY-MM-DD format)"
    }
  }
}
